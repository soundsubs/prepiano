{
  "id": "prepiano",
  "name": "PrePiano",
  "abbrev": "PPNO",
  "version": "0.1.10",
  "description": "Physically-modelled, preparable piano. Felt, bowing, gauge, hammer, sympathetic resonance, and prepared-piano disturbance.",
