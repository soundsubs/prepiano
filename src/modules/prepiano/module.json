      { "key": "attack",  "name": "Attack",  "type": "float", "min": 0, "max": 1, "step": 0.01, "default": 0.00 },
      { "key": "decay",   "name": "Decay",   "type": "float", "min": 0, "max": 1, "step": 0.01, "default": 0.55 },
      { "key": "gauge",   "name": "Gauge",   "type": "float", "min": 0, "max": 1, "step": 0.01, "default": 0.20 },
      { "key": "hammer",  "name": "Hammer",  "type": "float", "min": 0, "max": 1, "step": 0.01, "default": 0.40 },
      { "key": "symp",    "name": "Symp",    "type": "float", "min": 0, "max": 1, "step": 0.01, "default": 0.25 },
      { "key": "disturb", "name": "Disturb", "type": "float", "min": 0, "max": 1, "step": 0.01, "default": 0.00 },
      { "key": "reverb",  "name": "Reverb",  "type": "float", "min": 0, "max": 1, "step": 0.01, "default": 0.25 }
    ]
