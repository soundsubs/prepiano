          { "key": "attack",  "name": "Attack",  "type": "float", "min": 0, "max": 1, "step": 0.01 },
          { "key": "decay",   "name": "Decay",   "type": "float", "min": 0, "max": 1, "step": 0.01 },
          { "key": "gauge",   "name": "Gauge",   "type": "float", "min": 0, "max": 1, "step": 0.01 },
          { "key": "hammer",  "name": "Hammer",  "type": "float", "min": 0, "max": 1, "step": 0.01 },
          { "key": "symp",    "name": "Symp",    "type": "float", "min": 0, "max": 1, "step": 0.01 },
          { "key": "disturb", "name": "Disturb", "type": "float", "min": 0, "max": 1, "step": 0.01 },
